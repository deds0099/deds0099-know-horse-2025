# Variáveis de ambiente do projeto Know Horse 2025
# Copie este arquivo para .env e preencha com os valores do seu Supabase

# URL do projeto Supabase
# Encontre em: Project Settings > API > Project URL
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Chave anon (pública) do Supabase
# Encontre em: Project Settings > API > anon public
VITE_SUPABASE_ANON_KEY=eyJ...sua_chave_anon_aqui...

# Chave Pública do Mercado Pago (Checkout Pro)
VITE_MERCADOPAGO_PUBLIC_KEY=sua_chave_publica_aqui
